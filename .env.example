# ============================================================
# 游戏预发布内容审核系统 — 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际值
#   cp .env.example .env
# ============================================================

# --- 应用 (可选) ---
APP_ENV=development
# DEBUG=false
# HOST=0.0.0.0
# PORT=8000

# --- 数据库 (必填) ---
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/safe_launch
# DATABASE_POOL_SIZE=10
# DATABASE_POOL_OVERFLOW=20

# --- Redis (可选，默认 localhost) ---
# REDIS_URL=redis://localhost:6379/0

# --- DeepSeek LLM (必填) ---
# DEEPSEEK_API_KEY=<your-deepseek-api-key>
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_TIMEOUT=60

# --- Qdrant 向量数据库 (可选，默认 localhost) ---
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION_NAME=game_regulations

# --- OpenAI Embedding (必填，用于 RAG) ---
# OPENAI_API_KEY=<your-openai-api-key>
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- 图片检测私有服务 (可选，不配则图片审核转为人工) ---
# IMAGE_REVIEW_API_URL=http://internal-detector:5000/api/v1/detect
# IMAGE_REVIEW_API_KEY=
# IMAGE_REVIEW_TIMEOUT=30

# --- 审核业务配置 ---
# BATCH_MAX_SIZE=100
# BATCH_CONCURRENCY=5
