# ============================================================
.uv/

# ============================================================
# Environment (敏感信息，绝不提交)
# ============================================================
.env
.env.local
.env.*.local
*.env

# .env.example 是模板，需要提交
!.env.example

# ============================================================
# Claude Code (本地会话和设置)
